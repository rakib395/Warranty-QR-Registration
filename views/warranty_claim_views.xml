<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_warranty_claim_reject_wizard_form" model="ir.ui.view">
        <field name="name">warranty.claim.reject.wizard.form</field>
        <field name="model">warranty.claim.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Warranty Claim">
                <group>
                    <field name="rejection_reason" placeholder="Please enter the mandatory rejection reason here..."/>
                </group>
                <footer>
                    <button string="Confirm Reject" name="action_reject_claim" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_warranty_claim_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Claim Reason</field>
        <field name="res_model">warranty.claim.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_ms_warranty_claim_list" model="ir.ui.view">
        <field name="name">ms.warranty.claim.list</field>
        <field name="model">ms.warranty.claim</field>
        <field name="arch" type="xml">
            <list string="Warranty Claims">
                <field name="name"/>
                <field name="registration_id"/>
                <field name="issue_category"/>
                <field name="preferred_contact"/>
                <field name="create_date" string="Submitted On"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'submitted'"
                       decoration-warning="state == 'under_review'"
                       decoration-success="state in ('approved','resolved')"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_ms_warranty_claim_form" model="ir.ui.view">
        <field name="name">ms.warranty.claim.form</field>
        <field name="model">ms.warranty.claim</field>
        <field name="arch" type="xml">
            <form string="Warranty Claim">
                <header>
                    <button name="action_under_review" string="Mark Under Review" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve Claim" type="object" class="oe_highlight btn-success" invisible="state != 'under_review'"/>
                    <button name="%(action_warranty_claim_reject_wizard)d" string="Reject Claim" type="action" class="btn-danger" invisible="state != 'under_review'"/>
                    <button name="action_resolved" string="Mark Resolved" type="object" class="oe_highlight btn-info" invisible="state != 'approved'"/>
                    
                    <button name="action_reset_to_review" string="Reset to Review" type="object" class="btn-secondary" invisible="state not in ('approved', 'rejected', 'resolved')"/>

                    <field name="state" widget="statusbar" statusbar_visible="submitted,under_review,approved,resolved"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="registration_id"/>
                            <field name="issue_category"/>
                            <field name="preferred_contact"/>
                        </group>

                        <group>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Fault Description">
                            <field name="description"
                                   placeholder="Customer issue description..."/>
                        </page>

                        <page string="Attachments / Proofs">

                            <group>
                                <field name="product_photo"
                                       widget="image"
                                       class="oe_avatar"
                                       options="{'size': [200, 200]}"/>

                                <field name="invoice_proof"
                                       widget="binary"/>
                            </group>

                        </page>

                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ms_warranty_claim" model="ir.actions.act_window">
        <field name="name">Warranty Claims</field>
        <field name="res_model">ms.warranty.claim</field>
        <field name="view_mode">list,form</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No warranty claims found!
            </p>

            <p>
                Claims submitted from the public portal will appear here.
            </p>
        </field>
    </record>

</odoo>