<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_service_center" model="ir.ui.view">
        <field name="name">res.users.form.inherit.service.center</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Service Center Assignment" priority="1">
                    <field name="service_center_id" string="Assigned Service Center" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>