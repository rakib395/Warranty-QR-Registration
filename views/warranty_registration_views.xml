<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_ms_warranty_registration_tree" model="ir.ui.view">
        <field name="name">ms.warranty.registration.list</field>
        <field name="model">ms.warranty.registration</field>
        <field name="arch" type="xml">
            <list string="Warranty Registrations" decoration-info="state == 'pending'" decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="product_id"/>
                <field name="serial_no"/>
                <field name="expiry_date"/>
                <field name="state" widget="badge" decoration-info="state == 'pending'" decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ms_warranty_registration_form" model="ir.ui.view">
        <field name="name">ms.warranty.registration.form</field>
        <field name="model">ms.warranty.registration</field>
        <field name="arch" type="xml">
            <form string="Warranty Registration">
                <header>
                    <button name="action_submit" string="Pending Approval" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"/>

                    <button name="action_approve" string="Approve" type="object" 
                            class="oe_highlight" invisible="state != 'pending'"/>
                    
                    <button name="action_reject" string="Reject" type="object" 
                            invisible="state != 'pending'"/>

                    <button name="action_draft" string="Set to Draft" type="object" 
                            invisible="state not in ['approved', 'rejected', 'expired']"/>

                    <button name="action_expire" string="Set Expired" type="object" 
                            invisible="state != 'approved'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,expired"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Customer Information">
                            <field name="customer_name"/>
                            <field name="customer_phone"/>
                            <field name="customer_email"/>
                        </group>
                        <group string="Product Information">
                            <field name="product_id"/>
                            <field name="serial_no"/>
                            <field name="policy_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Purchase Details">
                            <field name="purchase_date"/>
                            <field name="dealer_id"/>
                            <field name="invoice_proof" filename="invoice_name"/>
                        </group>
                        <group string="Warranty Dates">
                            <field name="registration_date"/>
                            <field name="expiry_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ms_warranty_registration" model="ir.actions.act_window">
        <field name="name">Warranty Registrations</field>
        <field name="res_model">ms.warranty.registration</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>