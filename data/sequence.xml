<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Warranty Registration -->
        <record id="seq_ms_warranty_registration" model="ir.sequence">
            <field name="name">Warranty Registration</field>
            <field name="code">ms.warranty.registration</field>
            <field name="prefix">REG/%(range_year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Serial No. -->
        <record id="seq_warranty_simple_serial" model="ir.sequence">
            <field name="name">Warranty Simple Serial</field>
            <field name="code">ms.warranty.simple.serial</field>
            <field name="prefix"></field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="seq_ms_warranty_claim" model="ir.sequence">
            <field name="name">Warranty Claim Sequence</field>
            <field name="code">ms.warranty.claim</field>
            <field name="prefix">CLM/%(range_year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>