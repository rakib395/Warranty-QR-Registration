<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_warranty_expiry_scan" model="ir.cron">
            <field name="name">Warranty: Automated Expiry Scan</field>
            <field name="model_id" ref="ms_warranty_qr_claim_portal.model_ms_warranty_registration"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_warranty_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_warranty_claim_sla_scan" model="ir.cron">
            <field name="name">Warranty Claim: SLA Breach Monitor</field>
            <field name="model_id" ref="ms_warranty_qr_claim_portal.model_ms_warranty_claim"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_sla_breach()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>